{
    "version": 2,
    "builds": [
        {
            "src": "prarabdha_jyotish/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb"
            }
        },
        {
            "src": "build_files.sh",
            "use": "@vercel/static-build"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "prarabdha_jyotish/wsgi.py"
        }
    ]
}